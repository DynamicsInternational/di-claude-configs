{
  "description": "AL development hooks — compile on turn end",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/al-hook-record.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/al-hook-compile.js\"",
            "timeout": 120,
            "statusMessage": "Compiling AL..."
          }
        ]
      }
    ]
  }
}
